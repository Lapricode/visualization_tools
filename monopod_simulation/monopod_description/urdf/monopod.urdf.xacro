<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro" name="monopod">

  <!-- Define parameter -->
  <xacro:property name="base_color_rgba" value="0.8 0.2 0.2 1.0"/>
  <xacro:property name="leg_color_rgba" value="0.2 0.8 0.2 1.0"/>

  <!-- Cube base -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0.5" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia
        ixx="0.0133" iyy="0.0133" izz="0.0133"
        ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.5" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://meshes/cube_body.dae" />
      </geometry>
      <material name="base_color">
        <color rgba="${base_color_rgba}"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.5" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://meshes/cube_body.dae" />
      </geometry>
    </collision>
  </link>

  <!-- Joint 1: Pitch (X-axis) -->
  <joint name="joint_pitch" type="revolute">
    <parent link="base_link"/>
    <child link="intermediate_link"/>
    <origin xyz="0 0 -0.1" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit effort="10" velocity="1.0" lower="-1.57" upper="1.57"/>
  </joint>

  <!-- Intermediate link for universal joint -->
  <link name="intermediate_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="1e-6" iyy="1e-6" izz="1e-6" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Joint 2: Roll (Y-axis) -->
  <joint name="joint_roll" type="revolute">
    <parent link="intermediate_link"/>
    <child link="leg_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="10" velocity="1.0" lower="-1.57" upper="1.57"/>
  </joint>

  <!-- Cylindrical leg -->
  <link name="leg_link">
    <inertial>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia
        ixx="0.00104" iyy="0.00104" izz="0.00005"
        ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://meshes/cylindrical_leg.dae" />
      </geometry>
      <material name="leg_color">
        <color rgba="${leg_color_rgba}"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://meshes/cylindrical_leg.dae" />
      </geometry>
    </collision>
  </link>

</robot>
